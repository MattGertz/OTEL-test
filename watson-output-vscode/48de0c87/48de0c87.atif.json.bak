      {
        "type": "function",
        "name": "azure-sdk-mcp-azsdk_package_run_check",
        "description": "Run validation checks for SDK packages. Provide package path, check type (All, Changelog, Dependency, Readme, Cspell, Snippets), and whether to fix errors.",
        "parameters": {
          "type": "object",
          "properties": {
            "packagePath": {
              "type": "string"
            },
            "checkType": {
              "type": "string",
              "enum": [
                "All",
                "Changelog",
                "Dependency",
                "Readme",
                "Cspell",
                "Snippets",
                "Linting",
                "Format",
                "CheckAotCompat",
                "GeneratedCodeChecks",
                "Samples"
              ]
            },
            "fixCheckErrors": {
              "type": "boolean",
              "default": false
            }
          },
          "required": [
            "packagePath",
            "checkType"
          ]
        }
      },
      {
        "type": "function",
        "name": "azure-sdk-mcp-azsdk_package_run_tests",
        "description": "Run tests for the specified SDK package. Provide package path.",
        "parameters": {
          "type": "object",
          "properties": {
            "packagePath": {
              "type": "string"
            }
          },
          "required": [
            "packagePath"
          ]
        }
      },
      {
        "type": "function",
        "name": "azure-sdk-mcp-azsdk_package_translate_samples",
        "description": "Translates sample code files from a source package to a target package in a different programming language. Takes samples from the source package's samples directory, understands the functionality being demonstrated, and generates equivalent idiomatic code for the target language using the target package's APIs. Preserves the sample's intent and structure while adapting authentication patterns, error handling, and async conventions to match the target language's best practices.",
        "parameters": {
          "type": "object",
          "properties": {
            "fromPackagePath": {
              "description": "Path to the source package directory containing samples to translate.",
              "type": "string"
            },
            "toPackagePath": {
              "description": "Path to the target package directory where translated samples will be written.",
              "type": "string"
            },
            "overwrite": {
              "description": "Whether to overwrite existing sample files.",
              "type": "boolean",
              "default": false
            },
            "model": {
              "description": "Optional Azure OpenAI deployment name.",
              "type": "string",
              "default": null
            },
            "batchSize": {
              "description": "Number of samples to process per batch.",
              "type": "integer",
              "default": 5
            }
          },
          "required": [
            "fromPackagePath",
            "toPackagePath"
          ]
        }
      },
      {
        "type": "function",
        "name": "azure-sdk-mcp-azsdk_package_update_changelog_content",
        "description": "Updates the changelog content for a specified package.",
        "parameters": {
          "type": "object",
