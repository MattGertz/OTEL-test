        }
      },
      {
        "type": "function",
        "name": "azure-sdk-mcp-azsdk_package_update_version",
        "description": "Update or bump the version number for an SDK package. Sets the package version and release date in project files.",
        "parameters": {
          "type": "object",
          "properties": {
            "packagePath": {
              "description": "The absolute path to the package directory.",
              "type": "string"
            },
            "releaseType": {
              "description": "Specifies whether the next version is 'beta' or 'stable'.",
              "type": "string"
            },
            "version": {
              "description": "Specifies the next version number.",
              "type": "string"
            },
            "releaseDate": {
              "description": "The date (YYYY-MM-DD) to write into the changelog.",
              "type": "string"
            }
          },
          "required": [
