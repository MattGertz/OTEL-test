            "releaseType",
            "version",
            "releaseDate"
          ]
        }
      },
      {
        "type": "function",
        "name": "azure-sdk-mcp-azsdk_release_sdk",
        "description": "Releases the specified SDK package for a language. This includes checking if the package is ready for release and triggering the release pipeline. To ONLY check package release readiness pass checkReady as true.",
        "parameters": {
          "type": "object",
          "properties": {
            "packageName": {
              "type": "string"
            },
            "language": {
              "type": "string"
            },
            "branch": {
              "type": "string",
              "default": "main"
            },
            "checkReady": {
              "type": "boolean",
              "default": false
            }
          },
          "required": [
            "packageName",
            "language"
          ]
        }
      },
      {
        "type": "function",
        "name": "azure-sdk-mcp-azsdk_run_generate_sdk",
