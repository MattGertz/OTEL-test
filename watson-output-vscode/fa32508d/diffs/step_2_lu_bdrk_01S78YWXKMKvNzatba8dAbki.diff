+"""Show the test session details."""
+import json
+
+data = json.load(open('watson-output-vscode/48de0c87/48de0c87.atif.json', encoding='utf-8'))
+steps = data['steps']
+
+# Show all user messages
+print("USER MESSAGES:")
+print("=" * 80)
+for s in steps:
+    if s.get('source') == 'user':
+        msg = s.get('message', '')
+        if msg.startswith('<system'):
+            print(f"  Step {s['step_id']}: [system_notification] {msg[20:100]}...")
+        else:
+            print(f"  Step {s['step_id']}: {msg[:300]}")
+        print()
+
+# Show system instructions
+print("\nSYSTEM INSTRUCTIONS:")
+print("=" * 80)
+sys_instr = data.get('agent', {}).get('system_instructions', '')
+if sys_instr:
+    print(f"  ({len(sys_instr)} chars): {sys_instr[:200]}...")
+for s in steps:
+    if s.get('source') == 'system':
+        msg = s.get('message', '')
+        print(f"  Step {s['step_id']}: ({len(msg)} chars)")
+
+# Show agent messages (with text content)
+print("\nAGENT FLOW:")
+print("=" * 80)
+for s in steps:
+    sid = s['step_id']
+    source = s.get('source', '?')
+    metrics = s.get('metrics', {})
+    msg = s.get('message', '')
+    tool_calls = s.get('tool_calls', [])
+    observation = s.get('observation', {})
+    model = s.get('model_name', '')
+    reasoning = s.get('reasoning_content', '')
+    
+    if source == 'user':
+        if msg.startswith('<system'):
+            print(f"\n[{sid}] USER: [system_notification]")
+        else:
+            print(f"\n[{sid}] USER: {msg[:200]}")
+    elif source == 'agent':
+        tok_info = ""
+        if metrics:
+            tok_info = f" (in={metrics.get('prompt_tokens',0):,} out={metrics.get('completion_tokens',0):,} cached={metrics.get('cached_tokens',0):,})"
+        
+        if msg:
+            print(f"\n[{sid}] AGENT [{model}]{tok_info}: {msg[:300]}")
+        elif tool_calls:
+            tools = [tc.get('function_name', '?') for tc in tool_calls]
+            print(f"\n[{sid}] AGENT [{model}]{tok_info}: tool_calls={tools}")
+        elif metrics:
+            print(f"\n[{sid}] AGENT [{model}]{tok_info}")
+        
+        if reasoning:
+            print(f"    REASONING: {reasoning[:200]}...")
+        
+        if observation:
+            results = observation.get('results', [])
+            for r in results:
+                content = r.get('content', '')
+                if len(content) > 200:
+                    content = content[:200] + '...'
+                print(f"    OBSERVATION: {content}")
+    elif source == 'system':
+        print(f"\n[{sid}] SYSTEM: ({len(msg)} chars)")
+
+# Summary
+print("\n\nSUMMARY:")
+print("=" * 80)
+total_in = sum(s.get('metrics', {}).get('prompt_tokens', 0) for s in steps)
+total_out = sum(s.get('metrics', {}).get('completion_tokens', 0) for s in steps)
+total_cached = sum(s.get('metrics', {}).get('cached_tokens', 0) for s in steps)
+agent_steps = [s for s in steps if s.get('source') == 'agent']
+tool_steps = [s for s in steps if s.get('tool_calls')]
+all_tools = []
+for s in steps:
+    for tc in s.get('tool_calls', []):
+        all_tools.append(tc.get('function_name', '?'))
+print(f"Steps: {len(steps)} total, {len(agent_steps)} agent, {len(tool_steps)} with tool calls")
+print(f"Tokens: input={total_in:,} output={total_out:,} cached={total_cached:,}")
+print(f"Cache rate: {total_cached/total_in*100:.1f}%" if total_in > 0 else "")
+print(f"Tools used: {all_tools}")
+print(f"Unique tools: {sorted(set(all_tools))}")
+